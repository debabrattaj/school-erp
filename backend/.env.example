# Copy this file to `.env` in the same folder (backend/.env) and fill in real values.
# The app will NOT start without SECRET_KEY set.

# --- Required ---
# Used to sign JWT auth tokens. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-long-random-string

# --- Optional (defaults shown) ---
# How long a login token stays valid, in minutes. Default: 1440 (24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Comma-separated list of browser origins allowed to call this API (CORS).
# Default: the local Vite dev servers. In production set this to your real
# frontend URL(s), e.g. https://app.yourschool.com,https://admin.yourschool.com
# A wildcard "*" is NOT allowed because the API uses credentialed requests.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Login brute-force throttling. After LOGIN_MAX_ATTEMPTS failed logins from the
# same IP or against the same email within LOGIN_WINDOW_SECONDS, further
# attempts are blocked (HTTP 429) until the window passes.
LOGIN_MAX_ATTEMPTS=8
LOGIN_WINDOW_SECONDS=900

# --- Self-service password reset ---
# How long a reset link stays valid, in minutes. Default: 30
RESET_TOKEN_TTL_MINUTES=30
# Minimum length for a password chosen via reset. Default: 8
MIN_PASSWORD_LENGTH=8
# Frontend base URL used to build the reset link in the (currently logged) email.
FRONTEND_BASE_URL=http://localhost:5173
# DEV ONLY: when true, /auth/forgot-password returns the reset token in its JSON
# response so the flow is testable without an email transport. NEVER enable in
# production — it would let anyone reset any account. Default: false
RESET_DEBUG_RETURN_TOKEN=false

# --- Email (SMTP) ---
# Leave SMTP_HOST empty to run in log-only mode: outgoing emails (e.g. password
# reset links) are written to the server log instead of being sent. Set these
# to a real SMTP provider to actually deliver mail.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@schoolerp.local
# STARTTLS (typical for port 587). Set false + SMTP_USE_SSL=true for port 465.
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT=10

# --- WhatsApp (Twilio) ---
# Used for both the WhatsApp and SMS communication channels (SMS is sent over
# WhatsApp). Leave TWILIO_ACCOUNT_SID empty for log-only mode: messages are
# logged instead of sent. Set all three to deliver via Twilio's WhatsApp API.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Prepended to local numbers that lack a leading '+'. Default: +91 (India).
WHATSAPP_DEFAULT_COUNTRY_CODE=+91
WHATSAPP_TIMEOUT=10

# --- Database backups ---
# The owner console can always trigger a backup on demand. Set BACKUP_ENABLED
# true to also run them automatically on a schedule.
BACKUP_DIR=./backups
BACKUP_KEEP=14
BACKUP_ENABLED=false
BACKUP_INTERVAL_HOURS=24

# Central "directory" DB that maps school/account codes to their own database.
# Default: sqlite:///./school_accounts.db
CENTRAL_DATABASE_URL=sqlite:///./school_accounts.db

# Account code used when no tenant is specified (e.g. local dev, single-school setup).
# Default: default
DEFAULT_ACCOUNT_CODE=default

# Database used for the default/single-tenant school.
# Default: sqlite:///./school_erp.db
DEFAULT_SCHOOL_DATABASE_URL=sqlite:///./school_erp.db
